{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ~/.codex/hooks/codex_hook_bridge.py session-start",
            "statusMessage": "Registering Codex session"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ~/.codex/hooks/codex_hook_bridge.py stop",
            "statusMessage": "Finishing skill telemetry"
          }
        ]
      }
    ]
  }
}
